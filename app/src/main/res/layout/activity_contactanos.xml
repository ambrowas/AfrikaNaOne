<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="@drawable/trivialbackground"
    android:layout_height="match_parent"
    tools:context=".ContactanosActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:paddingLeft="20dp"
        android:text="Para ruegos, sugerencias, correciones, quejas, insultos y amenazas,
contáctenos por Whatsapp e intentaremos arreglarlo.Gracias por apoyarnos, saludos."
        android:textAlignment="viewStart"
        android:textColor="@color/black"
        android:textSize="16sp" />


    <ImageButton
        android:id="@+id/imagebuttonwhatsap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:src="@drawable/whatsapp"
        android:background="@drawable/rectangulo"
        tools:ignore="SpeakableTextPresentCheck" />

    <Button
        android:id="@+id/buttonregresar"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:text="VOLVER"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:background="@drawable/radio_selector_blue"
        android:layout_gravity="center_horizontal"
        app:strokeWidth="3dp"
        android:textColor="@color/white"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="6"/>




</LinearLayout>