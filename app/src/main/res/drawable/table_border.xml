<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/table_border.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <!-- Solid background color for the table -->
            <solid android:color="@color/white" />
            <!-- Border color and width for the table -->
            <stroke
                android:color="@color/black"
                android:width="6dp" />
            <!-- Optional padding for the border, adjust as needed -->
            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp" />
        </shape>
    </item>

    <!-- This is to keep the original background for the table. It's drawn on top of the border. -->
    <item android:drawable="@drawable/radio_normal3" />
</layer-list>
